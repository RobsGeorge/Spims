DATABASE_URL=postgresql://spims:spims@localhost:5432/spims
# Optional locally — leave empty to run background jobs inline (no Redis required)
REDIS_URL=
SESSION_SECRET=change-me-to-a-long-random-string-in-production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI — abstracted via lib/ai; app builds and runs without this key
GOOGLE_API_KEY=

# Object storage (S3-compatible — Cloudflare R2 or AWS S3)
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_KEY=
STORAGE_SECRET=

# Email
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@spims.example.com

# Payment gateways
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=
PAYMOB_API_KEY=
PAYMOB_HMAC=
PAYMOB_INTEGRATION_ID=
CASHIER_API_KEY=
CASHIER_SECRET=

# Zoom (Server-to-Server OAuth)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=

# Vimeo
VIMEO_TOKEN=

# Seed (production / first deploy)
SEED_ADMIN_EMAIL=admin@spims.local
SEED_ADMIN_PASSWORD=change-me-on-first-deploy

# Backups (VPS cron)
BACKUP_DIR=/var/backups/spims
BACKUP_OFFSITE_PATH=
