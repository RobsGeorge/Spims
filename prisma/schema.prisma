generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  SUPER_ADMIN
  ADMINISTRATIVE_ADMIN
  ACADEMIC_ADMIN
  FINANCIAL_ADMIN
  INSTRUCTOR
  TA
  STUDENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

enum TranslationSource {
  AI
  HUMAN
}

enum ProgramType {
  DIPLOMA
  CERTIFICATE
  DEGREE
}

enum RequirementType {
  REQUIRED
  ELECTIVE
}

enum OfferingMode {
  COHORT
  SELF_PACED
}

enum OfferingStaffRole {
  INSTRUCTOR
  TA
}

enum OfferingStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum ContentItemType {
  VIDEO
  READING
  TEXT
  ASSIGNMENT
  QUIZ
  EXAM
  DISCUSSION
}

enum SubmissionType {
  FILE
  TEXT
  BOTH
}

enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTI
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
  MATCHING
  FILL_BLANK
  NUMERIC
  ORDERING
  FILE_UPLOAD
}

enum AssessmentMode {
  QUIZ
  EXAM
}

enum ScoringRule {
  HIGHEST
  LATEST
  AVERAGE
}

enum ResultsVisibility {
  IMMEDIATE
  AFTER_CLOSE
  ON_RELEASE
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
  GRADED
}

enum ComponentKind {
  ASSIGNMENT
  QUIZ
  EXAM
  ATTENDANCE
  DISCUSSION
  OTHER
}

enum GradeType {
  STANDARD
  WITHDRAWAL
  PASS_FAIL
  AUDIT
  IN_PROGRESS
}

enum EnrollmentStatus {
  ENROLLED
  WAITLISTED
  DROPPED
  WITHDRAWN
  COMPLETED
}

enum GradeStatus {
  IN_PROGRESS
  SUBMITTED
  LOCKED
}

enum StudentProgramStatus {
  ACTIVE
  COMPLETED
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum AttendanceSource {
  ZOOM_IMPORT
  MANUAL
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  WAITLISTED
}

enum FormFieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SELECT
  MULTISELECT
  FILE
  CHECKBOX
}

enum Currency {
  EGP
  USD
}

enum WalletKind {
  MONEY
  POINTS
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum LedgerReason {
  TOPUP
  REFUND
  PAYMENT
  DONATION
  ADMIN_GRANT
  ADJUSTMENT
}

enum PaymentMethod {
  PAYPAL
  PAYMOB
  CASHIER
  WALLET_MONEY
  WALLET_POINTS
  MANUAL_CASH
  MANUAL_TRANSFER
  MANUAL_CHEQUE
}

enum PaymentStatus {
  PENDING
  PENDING_VERIFICATION
  COMPLETED
  FAILED
  REFUNDED
}

enum InvoiceStatus {
  OPEN
  PARTIAL
  PAID
  VOID
  REFUNDED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum CredentialType {
  TRANSCRIPT
  PROGRAM_CERTIFICATE
  STANDALONE_CERTIFICATE
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum ThreadVisibility {
  OPEN
  PRIVATE_TO_INSTRUCTOR
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  phone           String?
  firstName       String
  lastName        String
  passwordHash    String?
  emailVerified   Boolean         @default(false)
  preferredLocale String          @default("en")
  themePreference ThemePreference @default(SYSTEM)
  countryCode     String?
  status          UserStatus      @default(PENDING)
  isReviewer      Boolean         @default(false)
  lastReviewedAt  DateTime?
  roles            UserRole[]
  sessions         Session[]
  otpTokens        OtpToken[]
  wallet           WalletAccount?
  applications     Application[]
  enrollments      Enrollment[]
  studentPrograms  StudentProgram[]
  academicRecords  AcademicRecord[]
  offeringStaff    OfferingStaff[]
  submissions      AssignmentSubmission[]
  attempts         AssessmentAttempt[]
  attendance       AttendanceRecord[]
  discussionPosts  DiscussionPost[]
  discussionGrades DiscussionGrade[]
  interestFlags    CourseInterestFlag[]
  notifications    Notification[]
  credentials      Credential[]
  donations        Donation[]
  invoices         Invoice[]
  payments         Payment[]
  paymentBatches   PaymentBatch[]
  weekProgress     WeekProgress[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?
  @@index([status])
}

model UserRole {
  id     String   @id @default(cuid())
  userId String
  role   RoleType
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpToken {
  id         String     @id @default(cuid())
  userId     String
  purpose    OtpPurpose
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Language {
  code    String  @id
  name    String
  isRtl   Boolean @default(false)
  enabled Boolean @default(true)
}

model Translation {
  id          String            @id @default(cuid())
  entityType  String
  entityId    String
  field       String
  locale      String
  value       String
  source      TranslationSource @default(HUMAN)
  verified    Boolean           @default(false)
  updatedById String?
  updatedAt   DateTime          @updatedAt
  @@unique([entityType, entityId, field, locale])
  @@index([entityType, entityId])
}

model GradingScheme {
  id        String      @id @default(cuid())
  name      String
  isDefault Boolean     @default(false)
  bands     GradeBand[]
  programs  Program[]
  createdAt DateTime    @default(now())
}

model GradeBand {
  id         String        @id @default(cuid())
  schemeId   String
  letter     String
  minPercent Float
  maxPercent Float
  gpaPoints  Float
  isPassing  Boolean
  scheme     GradingScheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)
}

model AssessmentTemplate {
  id         String                        @id @default(cuid())
  name       String
  isDefault  Boolean                       @default(false)
  components AssessmentTemplateComponent[]
  courses    Course[]
  createdAt  DateTime                      @default(now())
}

model AssessmentTemplateComponent {
  id            String             @id @default(cuid())
  templateId    String
  name          String
  weightPercent Float
  kind          ComponentKind
  template      AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Program {
  id                      String      @id @default(cuid())
  code                    String      @unique
  name                    String
  type                    ProgramType
  passingThreshold        Float       @default(60)
  maxCreditsPerSemester   Int
  maxCoursesPerSemester   Int
  maxSemestersToGraduate  Int
  electiveCreditsRequired Int         @default(0)
  signatoryName           String?
  signatoryTitle          String?
  gradingSchemeId         String?
  active                  Boolean     @default(true)
  gradingScheme    GradingScheme?   @relation(fields: [gradingSchemeId], references: [id])
  programCourses   ProgramCourse[]
  applicationForms ApplicationForm[]
  applications     Application[]
  studentPrograms  StudentProgram[]
  credentials      Credential[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Course {
  id                   String  @id @default(cuid())
  code                 String  @unique
  title                String
  creditHours          Int
  defaultPriceUsd      Int     @default(0)
  defaultPriceEgp      Int     @default(0)
  isFree               Boolean @default(false)
  isStandalone         Boolean @default(false)
  passingThreshold     Float?
  assessmentTemplateId String?
  active               Boolean @default(true)
  assessmentTemplate AssessmentTemplate?  @relation(fields: [assessmentTemplateId], references: [id])
  programCourses     ProgramCourse[]
  prerequisitesFor   CoursePrerequisite[] @relation("RequiresCourse")
  prerequisites      CoursePrerequisite[] @relation("PrerequisiteCourse")
  offerings          CourseOffering[]
  questionBanks      QuestionBank[]
  academicRecords    AcademicRecord[]
  interestFlags      CourseInterestFlag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model CoursePrerequisite {
  id             String @id @default(cuid())
  courseId       String
  prerequisiteId String
  course         Course @relation("RequiresCourse", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisite   Course @relation("PrerequisiteCourse", fields: [prerequisiteId], references: [id])
  @@unique([courseId, prerequisiteId])
}

model ProgramCourse {
  id           String          @id @default(cuid())
  programId    String
  courseId     String
  requirement  RequirementType
  yearLevel    Int?
  program      Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  course       Course          @relation(fields: [courseId], references: [id])
  fulfillments ProgramRequirementFulfillment[]
  @@unique([programId, courseId])
}

model AcademicYear {
  id        String     @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  semesters Semester[]
}

model Semester {
  id                      String         @id @default(cuid())
  academicYearId          String
  name                    String
  startDate               DateTime
  endDate                 DateTime
  registrationStart       DateTime
  registrationEnd         DateTime
  addDropEndWeek          Int
  lastWithdrawalWeek      Int
  withdrawalRefundPercent Float          @default(0)
  status                  OfferingStatus @default(DRAFT)
  academicYear            AcademicYear   @relation(fields: [academicYearId], references: [id])
  offerings               CourseOffering[]
}

model CourseOffering {
  id                         String         @id @default(cuid())
  courseId                   String
  semesterId                 String?
  mode                       OfferingMode   @default(COHORT)
  priceUsdOverride           Int?
  priceEgpOverride           Int?
  seatCapacity               Int?
  attendanceThresholdPercent Float          @default(60)
  status                     OfferingStatus @default(DRAFT)
  startDate                  DateTime?
  endDate                    DateTime?
  course          Course          @relation(fields: [courseId], references: [id])
  semester        Semester?       @relation(fields: [semesterId], references: [id])
  staff           OfferingStaff[]
  weeks           Week[]
  liveSessions    LiveSession[]
  recurrences     SessionRecurrence[]
  assessments     Assessment[]
  gradebookComponents GradebookComponent[]
  enrollments     Enrollment[]
  announcements   Announcement[]
  discussionBoard DiscussionBoard?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  @@index([courseId])
  @@index([semesterId])
}

model OfferingStaff {
  id         String            @id @default(cuid())
  offeringId String
  userId     String
  role       OfferingStaffRole
  offering   CourseOffering    @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id])
  @@unique([offeringId, userId, role])
}

model Week {
  id         String         @id @default(cuid())
  offeringId String
  number     Int
  title      String
  unlockDate DateTime?
  order      Int
  offering   CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  items      ContentItem[]
  progress   WeekProgress[]
  @@unique([offeringId, number])
}

model WeekProgress {
  id          String   @id @default(cuid())
  studentId   String
  weekId      String
  completedAt DateTime @default(now())
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  week        Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  @@unique([studentId, weekId])
  @@index([studentId])
}

model ContentItem {
  id         String          @id @default(cuid())
  weekId     String
  type       ContentItemType
  title      String
  order      Int
  vimeoId    String?
  fileUrl    String?
  body       String?
  week       Week            @relation(fields: [weekId], references: [id], onDelete: Cascade)
  assignment Assignment?
  assessment Assessment?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Assignment {
  id                  String         @id @default(cuid())
  contentItemId       String         @unique
  componentId         String?
  instructions        String
  submissionType      SubmissionType @default(BOTH)
  allowedFileTypes    String[]
  maxPoints           Float          @default(100)
  itemWeight          Float?
  released            Boolean        @default(false)
  dueDate             DateTime?
  latePenaltyOverride Float?
  contentItem         ContentItem         @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  component           GradebookComponent? @relation(fields: [componentId], references: [id])
  submissions         AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  textBody     String?
  fileUrl      String?
  submittedAt  DateTime   @default(now())
  isLate       Boolean    @default(false)
  rawScore     Float?
  finalScore   Float?
  feedback     String?
  gradedById   String?
  gradedAt     DateTime?
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User       @relation(fields: [studentId], references: [id])
  @@unique([assignmentId, studentId])
}

model SessionRecurrence {
  id              String         @id @default(cuid())
  offeringId      String
  daysOfWeek      Int[]
  startTime       String
  durationMinutes Int
  startDate       DateTime
  endDate         DateTime
  offering        CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
}

model LiveSession {
  id              String           @id @default(cuid())
  offeringId      String
  title           String
  scheduledStart  DateTime
  durationMinutes Int
  zoomMeetingId   String?
  zoomJoinUrl     String?
  zoomStartUrl    String?
  recordingUrl    String?
  offering        CourseOffering   @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  attendance      AttendanceRecord[]
  @@index([offeringId, scheduledStart])
}

model AttendanceRecord {
  id              String           @id @default(cuid())
  liveSessionId   String
  studentId       String
  status          AttendanceStatus
  minutesAttended Int              @default(0)
  source          AttendanceSource @default(ZOOM_IMPORT)
  overriddenById  String?
  updatedAt       DateTime         @updatedAt
  liveSession     LiveSession      @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  student         User             @relation(fields: [studentId], references: [id])
  @@unique([liveSessionId, studentId])
}

model QuestionBank {
  id        String     @id @default(cuid())
  courseId  String
  name      String
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]
}

model Question {
  id          String       @id @default(cuid())
  bankId      String
  type        QuestionType
  prompt      String
  points      Float        @default(1)
  config      Json?
  aiKeyPoints String?
  aiGuidance  String?
  bank        QuestionBank        @relation(fields: [bankId], references: [id], onDelete: Cascade)
  options     QuestionOption[]
  assessmentQuestions AssessmentQuestion[]
  answers     AttemptAnswer[]
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  matchKey   String?
  order      Int      @default(0)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Assessment {
  id                String            @id @default(cuid())
  offeringId        String
  contentItemId     String?           @unique
  componentId       String?
  mode              AssessmentMode
  title             String
  language          String            @default("en")
  timeLimitMinutes  Int?
  opensAt           DateTime?
  closesAt          DateTime?
  attemptsAllowed   Int               @default(1)
  scoringRule       ScoringRule       @default(HIGHEST)
  shuffleQuestions  Boolean           @default(true)
  shuffleOptions    Boolean           @default(true)
  drawFromBankId    String?
  questionsToDraw   Int?
  resultsVisibility ResultsVisibility @default(ON_RELEASE)
  revealAnswers     Boolean           @default(false)
  enforceFullScreen Boolean           @default(false)
  oneAtATime        Boolean           @default(false)
  noBacktrack       Boolean           @default(false)
  logFocusLoss      Boolean           @default(true)
  maxPoints         Float             @default(100)
  itemWeight        Float?
  released          Boolean           @default(false)
  offering    CourseOffering      @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  contentItem ContentItem?        @relation(fields: [contentItemId], references: [id])
  component   GradebookComponent? @relation(fields: [componentId], references: [id])
  questions   AssessmentQuestion[]
  attempts    AssessmentAttempt[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssessmentQuestion {
  id             String     @id @default(cuid())
  assessmentId   String
  questionId     String
  order          Int        @default(0)
  pointsOverride Float?
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question       Question   @relation(fields: [questionId], references: [id])
  @@unique([assessmentId, questionId])
}

model AssessmentAttempt {
  id             String        @id @default(cuid())
  assessmentId   String
  studentId      String
  attemptNo      Int           @default(1)
  startedAt      DateTime      @default(now())
  dueAt          DateTime
  submittedAt    DateTime?
  status         AttemptStatus @default(IN_PROGRESS)
  totalScore     Float?
  focusLossCount Int           @default(0)
  questionIds    String[]      @default([])
  examSnapshot   Json?
  assessment     Assessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student        User          @relation(fields: [studentId], references: [id])
  answers        AttemptAnswer[]
  @@unique([assessmentId, studentId, attemptNo])
  @@index([status])
  @@index([status, dueAt])
}

model AttemptAnswer {
  id               String            @id @default(cuid())
  attemptId        String
  questionId       String
  response         Json?
  autoScore        Float?
  aiSuggestedScore Float?
  aiRationale      String?
  finalScore       Float?
  feedback         String?
  gradedById       String?
  gradedAt         DateTime?
  attempt          AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         Question          @relation(fields: [questionId], references: [id])
  @@unique([attemptId, questionId])
}

model GradebookComponent {
  id            String         @id @default(cuid())
  offeringId    String
  name          String
  weightPercent Float
  kind          ComponentKind
  offering      CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  assignments   Assignment[]
  assessments   Assessment[]
}

model Enrollment {
  id               String           @id @default(cuid())
  studentId        String
  offeringId       String
  studentProgramId String?
  status           EnrollmentStatus @default(ENROLLED)
  isAudit          Boolean          @default(false)
  enrolledAt       DateTime         @default(now())
  droppedAt        DateTime?
  gradeType        GradeType        @default(IN_PROGRESS)
  finalPercent     Float?
  finalLetter      String?
  finalGpaPoints   Float?
  gradeStatus      GradeStatus      @default(IN_PROGRESS)
  gradeLockedById  String?
  gradeLockedAt    DateTime?
  progressPercent  Float            @default(0)
  student        User            @relation(fields: [studentId], references: [id])
  offering       CourseOffering  @relation(fields: [offeringId], references: [id])
  studentProgram StudentProgram? @relation(fields: [studentProgramId], references: [id])
  academicRecord AcademicRecord?
  invoice        Invoice?
  @@unique([studentId, offeringId])
  @@index([status])
}

model StudentProgram {
  id          String               @id @default(cuid())
  studentId   String
  programId   String
  status      StudentProgramStatus @default(ACTIVE)
  enrolledAt  DateTime             @default(now())
  completedAt DateTime?
  cachedGpa   Float?
  student      User                 @relation(fields: [studentId], references: [id])
  program      Program              @relation(fields: [programId], references: [id])
  enrollments  Enrollment[]
  fulfillments ProgramRequirementFulfillment[]
  @@unique([studentId, programId])
}

model AcademicRecord {
  id           String      @id @default(cuid())
  studentId    String
  courseId     String
  enrollmentId String?     @unique
  letterGrade  String
  percent      Float
  gpaPoints    Float
  creditHours  Int
  term         String
  isPassing    Boolean
  completedAt  DateTime    @default(now())
  student      User        @relation(fields: [studentId], references: [id])
  course       Course      @relation(fields: [courseId], references: [id])
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id])
  fulfillments ProgramRequirementFulfillment[]
  @@index([studentId, courseId])
}

model ProgramRequirementFulfillment {
  id               String         @id @default(cuid())
  studentProgramId String
  programCourseId  String
  academicRecordId String
  appliedAt        DateTime       @default(now())
  studentProgram   StudentProgram @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  programCourse    ProgramCourse  @relation(fields: [programCourseId], references: [id])
  academicRecord   AcademicRecord @relation(fields: [academicRecordId], references: [id])
  @@unique([studentProgramId, programCourseId])
}

model CourseInterestFlag {
  id        String   @id @default(cuid())
  studentId String
  courseId  String
  createdAt DateTime @default(now())
  student   User     @relation(fields: [studentId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  @@unique([studentId, courseId])
}

model Credential {
  id             String         @id @default(cuid())
  studentId      String
  type           CredentialType
  programId      String?
  offeringId     String?
  serial         String         @unique
  qrToken        String         @unique
  language       String         @default("en")
  signatoryName  String?
  signatoryTitle String?
  fileUrl        String?
  issuedAt       DateTime       @default(now())
  revokedAt      DateTime?
  student        User           @relation(fields: [studentId], references: [id])
  program        Program?       @relation(fields: [programId], references: [id])
}

model ApplicationForm {
  id           String                 @id @default(cuid())
  programId    String
  name         String
  active       Boolean                @default(true)
  program      Program                @relation(fields: [programId], references: [id], onDelete: Cascade)
  fields       ApplicationFormField[]
  applications Application[]
}

model ApplicationFormField {
  id               String          @id @default(cuid())
  formId           String
  label            String
  type             FormFieldType
  required         Boolean         @default(false)
  order            Int
  options          String[]
  allowedFileTypes String[]
  adminNote        String?
  form             ApplicationForm        @relation(fields: [formId], references: [id], onDelete: Cascade)
  values           ApplicationFieldValue[]
}

model Application {
  id           String            @id @default(cuid())
  applicantId  String
  programId    String
  formId       String
  status       ApplicationStatus @default(DRAFT)
  reviewerId   String?
  decisionNote String?
  submittedAt  DateTime?
  decidedAt    DateTime?
  applicant    User            @relation(fields: [applicantId], references: [id])
  program      Program         @relation(fields: [programId], references: [id])
  form         ApplicationForm @relation(fields: [formId], references: [id])
  values       ApplicationFieldValue[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([applicantId, programId])
  @@index([status])
}

model ApplicationFieldValue {
  id            String               @id @default(cuid())
  applicationId String
  fieldId       String
  value         String?
  fileUrl       String?
  application   Application          @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  field         ApplicationFormField @relation(fields: [fieldId], references: [id])
  @@unique([applicationId, fieldId])
}

model Invoice {
  id           String        @id @default(cuid())
  studentId    String
  enrollmentId String?       @unique
  currency     Currency
  totalMinor   Int
  status       InvoiceStatus @default(OPEN)
  dueDate      DateTime?
  student      User          @relation(fields: [studentId], references: [id])
  enrollment   Enrollment?   @relation(fields: [enrollmentId], references: [id])
  lines        InvoiceLine[]
  payments     Payment[]
  batches      PaymentBatch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([studentId, status])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  offeringId  String?
  amountMinor Int
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model PaymentBatch {
  id             String        @id @default(cuid())
  idempotencyKey String        @unique
  invoiceId      String
  studentId      String
  currency       Currency
  totalMinor     Int
  status         PaymentStatus @default(PENDING)
  invoice        Invoice       @relation(fields: [invoiceId], references: [id])
  student        User          @relation(fields: [studentId], references: [id])
  payments       Payment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Payment {
  id            String        @id @default(cuid())
  studentId     String
  invoiceId     String?
  batchId       String?
  currency      Currency
  amountMinor   Int
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  gatewayRef    String?
  proofUrl      String?
  recordedById  String?
  verifiedById  String?
  receiptSerial String?       @unique
  receiptUrl    String?
  student       User          @relation(fields: [studentId], references: [id])
  invoice       Invoice?      @relation(fields: [invoiceId], references: [id])
  batch         PaymentBatch? @relation(fields: [batchId], references: [id])
  createdAt DateTime @default(now())
  @@index([status])
  @@index([batchId])
}

model WalletAccount {
  id             String              @id @default(cuid())
  userId         String              @unique
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   WalletTransaction[]
  egpMoneyMinor  Int                 @default(0)
  usdMoneyMinor  Int                 @default(0)
  egpPointsMinor Int                 @default(0)
  usdPointsMinor Int                 @default(0)
}

model WalletTransaction {
  id               String          @id @default(cuid())
  walletId         String
  currency         Currency
  kind             WalletKind
  direction        LedgerDirection
  amountMinor      Int
  reason           LedgerReason
  relatedPaymentId String?
  relatedInvoiceId String?
  note             String?
  createdById      String?
  createdAt        DateTime        @default(now())
  wallet           WalletAccount   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  @@index([walletId, currency, kind])
}

model Donation {
  id          String     @id @default(cuid())
  userId      String?
  amountMinor Int
  currency    Currency
  kind        WalletKind @default(MONEY)
  designation String?
  paymentId   String?
  createdAt   DateTime   @default(now())
  user        User?      @relation(fields: [userId], references: [id])
}

model Refund {
  id            String       @id @default(cuid())
  paymentId     String?
  enrollmentId  String?
  studentId     String
  amountMinor   Int
  currency      Currency
  asPoints      Boolean      @default(false)
  status        RefundStatus @default(REQUESTED)
  reason        String?
  requestedById String?
  approvedById  String?
  createdAt     DateTime     @default(now())
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  eventId     String
  payload     Json?
  processedAt DateTime @default(now())
  @@unique([provider, eventId])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  channel   NotificationChannel @default(IN_APP)
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, readAt])
}

model Announcement {
  id         String         @id @default(cuid())
  offeringId String
  authorId   String
  title      String
  body       String
  createdAt  DateTime       @default(now())
  offering   CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
}

model DiscussionBoard {
  id                  String           @id @default(cuid())
  offeringId          String           @unique
  allowStudentThreads Boolean          @default(true)
  offering            CourseOffering   @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  threads             DiscussionThread[]
}

model DiscussionThread {
  id                      String           @id @default(cuid())
  boardId                 String
  authorId                String
  title                   String
  visibility              ThreadVisibility @default(OPEN)
  isGraded                Boolean          @default(false)
  participationMinWords   Int?
  participationMinPosts   Int?
  participationMinReplies Int?
  locked                  Boolean          @default(false)
  pinned                  Boolean          @default(false)
  createdAt               DateTime         @default(now())
  board                   DiscussionBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  posts                   DiscussionPost[]
  grades                  DiscussionGrade[]
}

model DiscussionPost {
  id           String           @id @default(cuid())
  threadId     String
  authorId     String
  parentPostId String?
  body         String
  attachments  String[]
  createdAt    DateTime         @default(now())
  editedAt     DateTime?
  deletedAt    DateTime?
  thread       DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author       User             @relation(fields: [authorId], references: [id])
  parent       DiscussionPost?  @relation("PostReplies", fields: [parentPostId], references: [id])
  replies      DiscussionPost[] @relation("PostReplies")
}

model DiscussionGrade {
  id         String           @id @default(cuid())
  threadId   String
  studentId  String
  autoScore  Float?
  finalScore Float?
  overridden Boolean          @default(false)
  feedback   String?
  gradedById String?
  gradedAt   DateTime?
  thread     DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  student    User             @relation(fields: [studentId], references: [id])
  @@unique([threadId, studentId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  action     String
  entityType String?
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  requestId  String?
  createdAt  DateTime @default(now())
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

model Setting {
  key         String   @id
  value       Json
  updatedById String?
  updatedAt   DateTime @updatedAt
}

model Theme {
  id           String   @id @default(cuid())
  name         String
  isActive     Boolean  @default(false)
  siteName     String   @default("Spims")
  logoLightUrl String?
  logoDarkUrl  String?
  faviconUrl   String?
  tokens       Json
  updatedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
